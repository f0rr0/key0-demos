{
	"name": "key0-demos",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.8",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev:firecrawl": "bun --cwd apps/firecrawl-native-demo run dev",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "bunx tsgo -p tsconfig.json --noEmit",
		"test": "bun test",
		"check": "bun run lint && bun run typecheck && bun run test",
		"prepare": "lefthook install"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.7",
		"@types/bun": "^1.3.10",
		"@types/node": "^25.5.0",
		"@typescript/native-preview": "7.0.0-dev.20260318.1",
		"lefthook": "2.1.4"
	}
}
